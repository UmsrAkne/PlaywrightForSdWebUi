<Window
    x:Class="PlaywrightForSdWebUi.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:viewModels="clr-namespace:PlaywrightForSdWebUi.ViewModels"
    Title="{Binding Title}"
    Width="525"
    Height="350"
    d:DataContext="{d:DesignInstance viewModels:MainWindowViewModel}"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <Grid>
        <StackPanel Margin="20">
            <Button
                x:Name="BtnConnect"
                Height="40"
                Command="{Binding OpenBrowserCommand}"
                Content="WebUI をブラウザで開く" />
            <Button
                x:Name="BtnSendPrompt"
                Height="40"
                Margin="0,10,0,0"
                Command="{Binding GenerateImageCommand}"
                Content="プロンプトを送信して生成" />
        </StackPanel>
    </Grid>
</Window>