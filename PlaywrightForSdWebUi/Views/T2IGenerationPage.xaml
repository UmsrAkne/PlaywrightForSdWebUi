<UserControl
    x:Class="PlaywrightForSdWebUi.Views.T2IGenerationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:PlaywrightForSdWebUi.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:T2IGenerationPageViewModel}"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <StackPanel Margin="10">
        <StackPanel Margin="0,0,0,10">
            <TextBlock FontWeight="Bold" Text="Prompt" />
            <TextBox
                Height="60"
                AcceptsReturn="True"
                Text="{Binding PendingGenerationTask.Prompt, UpdateSourceTrigger=PropertyChanged}"
                TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Margin="0,0,0,10">
            <TextBlock FontWeight="Bold" Text="Negative Prompt" />
            <TextBox
                Height="60"
                AcceptsReturn="True"
                Text="{Binding PendingGenerationTask.NegativePrompt, UpdateSourceTrigger=PropertyChanged}"
                TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
            <StackPanel Margin="0,0,10,0">
                <TextBlock FontWeight="Bold" Text="Width" />
                <TextBox Width="100" Text="{Binding PendingGenerationTask.Width, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel>
                <TextBlock FontWeight="Bold" Text="Height" />
                <TextBox Width="100" Text="{Binding PendingGenerationTask.Height, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </StackPanel>

        <UniformGrid Columns="2">
            <Button
                Margin="0,0,5,0"
                Padding="10"
                Command="{Binding FetchSettingsCommand}"
                Content="ブラウザの設定を取得" />

            <Button
                Margin="5,0,0,0"
                Padding="10"
                Command="{Binding GenerateImageCommand}"
                Content="設定して生成" />
        </UniformGrid>
    </StackPanel>
</UserControl>